# Vina Doctor — AI Engine environment variables
# Copy this file to .env and fill in your values.

# Required: DashScope API key (https://console.aliyun.com)
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# ICD-10 enrichment feature (optional)
# Set to true to enable ICD-10 context injection into the Clinical Agent prompt.
# Can also be toggled at runtime via PATCH /v1/config/icd10-enrich (no restart needed).
VINA_ICD10_ENRICH_ENABLED=false

# Path to the ICD-10 treatment catalogue JSON file.
# Defaults to docs/icd10_treatment.json relative to the repo root.
# VINA_ICD10_DATA_PATH=/app/docs/icd10_treatment.json
