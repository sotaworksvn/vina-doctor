# Vina Doctor — Backend environment variables
# Copy to .env and fill in values before running

# Database (SQLite for dev, change to asyncpg URL for production)
DATABASE_URL=sqlite+aiosqlite:///./vina_doctor.db
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/vina_doctor

# AI Engine service URL
AI_ENGINE_URL=http://localhost:8001
AI_ENGINE_TIMEOUT=120.0

# JWT — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=changeme_generate_a_real_secret

# Audio file storage (local path)
AUDIO_STORAGE_PATH=./audio_uploads
