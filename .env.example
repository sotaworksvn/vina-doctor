# Copy this file to .env and fill in your values before running docker compose.

# ── AI Engine ─────────────────────────────────────────────────────────────────
# Alibaba Cloud DashScope API key for Qwen2-Audio
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Password for the postgres Docker container (user: vina, db: vina_doctor)
POSTGRES_PASSWORD=changeme_strong_password

# ── Backend ───────────────────────────────────────────────────────────────────
# JWT secret — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=changeme_generate_a_real_secret

# DATABASE_URL is overridden in docker-compose.yml to point at the postgres
# container. Set this only for local (non-Docker) development:
# DATABASE_URL=postgresql+asyncpg://vina:changeme@localhost:5432/vina_doctor
